# GigaChat API (получить в личном кабинете SberDevices)
GIGACHAT_CLIENT_ID=your-client-id
GIGACHAT_CLIENT_SECRET=your-base64-encoded-auth-key
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# PostgreSQL
POSTGRES_DB=kids_platform
POSTGRES_USER=kids_user
POSTGRES_PASSWORD=generate-strong-password-here

# Application
SECRET_KEY=generate-64-char-hex-here
DATABASE_URL=postgresql+asyncpg://kids_user:password@postgres/kids_platform
REDIS_URL=redis://redis:6379

# Environment
ENVIRONMENT=production

# TASK_STAGE1_v4.md: генерация уроков через новый generator->verifier пайплайн
# (lesson_pipeline.py) вместо старого монолитного (lesson_generator.py).
# false = старый путь (по умолчанию, безопасный откат — просто не менять это).
USE_NEW_LESSON_PIPELINE=false

# TASK_STAGE2.md: какой LLM-бэкенд использует НОВЫЙ пайплайн (lesson_pipeline.py
# через app/services/llm_client.py). Старый путь (lesson_generator.py) всегда
# ходит в GigaChat напрямую, эти переменные его не касаются.
# gigachat = старое поведение (по умолчанию). proxyapi = сильная модель, Этап 2.
LLM_PROVIDER=gigachat
# Ключ proxyapi.ru — НЕ коммитить реальное значение, только в .env на сервере.
PROXYAPI_KEY=
# Модель через proxyapi (см. https://proxyapi.ru/docs/anthropic-models).
PROXYAPI_MODEL=claude-sonnet-5
